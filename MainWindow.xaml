<Window
    x:Class="YxllowLoader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BrandBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="{StaticResource BrandBgBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="yxllow"
                           Foreground="{StaticResource BrandYellowBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="Bold"
                           FontSize="13"/>
                <TextBlock Text=" tech"
                           Foreground="{StaticResource BrandMutedBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Page Frame -->
        <Frame x:Name="ContentFrame" Grid.Row="1"/>
    </Grid>
</Window>
