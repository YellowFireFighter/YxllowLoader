<Window
    x:Class="YxllowLoader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="{StaticResource BrandBgBrush}" Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="{StaticResource BrandBgBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="yxllow"
                           Foreground="{StaticResource BrandYellowBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="Bold"
                           FontSize="13"/>
                <TextBlock Text=" tech"
                           Foreground="{StaticResource BrandMutedBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Page Frame -->
        <Frame x:Name="ContentFrame" Grid.Row="1"/>

        <!-- ── Splash / loading overlay ───────────────────────────────── -->
        <Grid x:Name="SplashOverlay"
              Grid.RowSpan="2"
              Background="{StaticResource BrandBgBrush}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <!-- Gradient glow, same as login page -->
            <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#28FFC300" Offset="0"/>
                        <GradientStop Color="#00080808" Offset="0.55"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="28">

                <!-- Pixel canvas — pixels added from code-behind -->
                <Canvas x:Name="PixelCanvas"
                        Width="96" Height="96"
                        HorizontalAlignment="Center"/>

                <!-- Loading label -->
                <TextBlock Text="LOADING"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrandMutedBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="11"
                           CharacterSpacing="400"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
