<Page
    x:Class="YxllowLoader.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBgBrush}">

    <Grid>
        <!-- Gradient background: top-left yellow glow -->
        <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#28FFC300" Offset="0"/>
                    <GradientStop Color="#00080808" Offset="0.55"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Second radial glow, bottom-right -->
        <Ellipse Width="700" Height="700"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-200,-200">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#18FFC300" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Login Card -->
        <Border Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource BrandSurfaceBrush}"
                BorderBrush="{StaticResource BrandBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="40,36">

            <StackPanel Spacing="0">

                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="yxllow"
                                   Foreground="{StaticResource BrandYellowBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="Bold"
                                   FontSize="34"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Text=".tech"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="Bold"
                                   FontSize="24"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="SDK LOADER"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="10"
                               CharacterSpacing="200"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel Spacing="12">

                    <!-- Username -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="USERNAME"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="10"
                                   CharacterSpacing="150"/>
                        <TextBox x:Name="UsernameBox"
                                 Style="{StaticResource YxllowTextBoxStyle}"
                                 PlaceholderText="Username"
                                 Height="42"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="PASSWORD"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="10"
                                   CharacterSpacing="150"/>
                        <Grid Height="42">
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{StaticResource YxllowPasswordBoxStyle}"
                                         PlaceholderText="Password"/>
                            <Button x:Name="PasswordRevealBtn"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,4"
                                    Click="PasswordRevealBtn_Click">
                                <FontIcon x:Name="PasswordRevealIcon"
                                          Glyph="&#xE7B3;"
                                          FontSize="14"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Error Message -->
                    <TextBlock x:Name="ErrorText"
                               Text=""
                               Foreground="{StaticResource BrandDangerBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"/>

                    <!-- Login Button -->
                    <Button x:Name="LoginBtn"
                            Style="{StaticResource YxllowButtonStyle}"
                            Height="44"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            Click="LoginBtn_Click">
                        <Grid>
                            <TextBlock x:Name="LoginBtnText"
                                       Text="LOGIN"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       CharacterSpacing="100"
                                       Foreground="#0A0A0A"/>
                            <ProgressRing x:Name="LoginSpinner"
                                          Width="18" Height="18"
                                          Foreground="#0A0A0A"
                                          Visibility="Collapsed"/>
                        </Grid>
                    </Button>

                </StackPanel>

                <!-- Footer -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,28,0,0"
                            Spacing="4">
                    <TextBlock Text="no account?"
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"/>
                    <HyperlinkButton Content="join discord"
                                     NavigateUri="https://discord.gg/yxllow"
                                     Foreground="{StaticResource BrandYellowBrush}"
                                     FontFamily="Segoe UI Variable Text"
                                     FontSize="12"
                                     Padding="0"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Version watermark -->
        <TextBlock Text="v1.0.0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,16,12"
                   Foreground="{StaticResource BrandMutedBrush}"
                   FontFamily="Segoe UI Variable Text"
                   FontSize="11"
                   Opacity="0.5"/>
    </Grid>
</Page>
