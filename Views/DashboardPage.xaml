<Page
    x:Class="YxllowLoader.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             LEFT SIDEBAR
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="{StaticResource BrandSurfaceBrush}"
              BorderBrush="{StaticResource BrandBorderBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" Margin="20,24,20,20">
                <TextBlock FontFamily="Segoe UI Variable Display"
                           FontWeight="Bold"
                           FontSize="22">
                    <Run Text="yxllow" Foreground="{StaticResource BrandYellowBrush}"/>
                </TextBlock>
                <TextBlock Text="SDK LOADER"
                           Foreground="{StaticResource BrandMutedBrush}"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           FontSize="9"
                           CharacterSpacing="250"
                           Margin="1,2,0,0"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                       Fill="{StaticResource BrandBorderBrush}" Margin="20,0"/>

            <!-- Nav Items -->
            <StackPanel Grid.Row="1" Margin="12,16,12,0" Spacing="2">

                <!-- Dashboard (active) -->
                <Border x:Name="NavDashboard"
                        Background="#1AFFC300"
                        CornerRadius="7"
                        Padding="12,9">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE80F;" FontSize="14"
                                  Foreground="{StaticResource BrandYellowBrush}"/>
                        <TextBlock Text="Dashboard"
                                   Foreground="{StaticResource BrandYellowBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Inject -->
                <Border x:Name="NavInject"
                        Background="Transparent"
                        CornerRadius="7"
                        Padding="12,9">
                    <Border.Resources>
                        <Style TargetType="Border"/>
                    </Border.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE756;" FontSize="14"
                                  Foreground="{StaticResource BrandMutedBrush}"/>
                        <TextBlock Text="Inject"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Settings -->
                <Border Background="Transparent" CornerRadius="7" Padding="12,9">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="14"
                                  Foreground="{StaticResource BrandMutedBrush}"/>
                        <TextBlock Text="Settings"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Discord -->
                <Border Background="Transparent" CornerRadius="7" Padding="12,9">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8BD;" FontSize="14"
                                  Foreground="{StaticResource BrandMutedBrush}"/>
                        <TextBlock Text="Discord"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- User Card (bottom of sidebar) -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrandSurface2Brush}"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            Width="34" Height="34"
                            CornerRadius="17"
                            Background="{StaticResource BrandYellowBrush}"
                            Margin="0,0,10,0">
                        <TextBlock x:Name="AvatarInitial"
                                   Text="?"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="#0A0A0A"/>
                    </Border>

                    <!-- Username + Plan -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="SidebarUsername"
                                   Text="..."
                                   Foreground="{StaticResource BrandTextBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="SidebarPlan"
                                   Text="..."
                                   Foreground="{StaticResource BrandYellowBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"/>
                    </StackPanel>

                    <!-- Logout -->
                    <Button Grid.Column="2"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            VerticalAlignment="Center"
                            Click="LogoutBtn_Click"
                            ToolTipService.ToolTip="Logout">
                        <FontIcon Glyph="&#xE8BB;" FontSize="13"
                                  Foreground="{StaticResource BrandMutedBrush}"/>
                    </Button>
                </Grid>
            </Border>

        </Grid>


        <!-- ══════════════════════════════════════════
             MAIN CONTENT
        ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="1" Padding="32,28,32,28">
            <StackPanel Spacing="0">

                <!-- Header -->
                <StackPanel Margin="0,0,0,28">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="welcome back,"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="18"/>
                        <TextBlock x:Name="HeaderUsername"
                                   Text="..."
                                   Foreground="{StaticResource BrandTextBrush}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="18"/>
                    </StackPanel>
                    <TextBlock x:Name="SubtitleText"
                               Text="your session is active"
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"/>
                </StackPanel>

                <!-- Account Info Cards -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Plan Card -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE736;" FontSize="13"
                                          Foreground="{StaticResource BrandYellowBrush}"/>
                                <TextBlock Text="PLAN"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           CharacterSpacing="200"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="CardPlan"
                                       Text="—"
                                       Foreground="{StaticResource BrandYellowBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="22"/>
                        </StackPanel>
                    </Border>

                    <!-- Expires Card -->
                    <Border Grid.Column="2"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE787;" FontSize="13"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                                <TextBlock Text="EXPIRES"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           CharacterSpacing="200"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock x:Name="CardExpiry"
                                           Text="—"
                                           Foreground="{StaticResource BrandTextBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="Bold"
                                           FontSize="18"/>
                                <Border x:Name="DaysLeftBadge"
                                        Background="#1AFFC300"
                                        CornerRadius="4"
                                        Padding="7,3">
                                    <TextBlock x:Name="CardDaysLeft"
                                               Text=""
                                               Foreground="{StaticResource BrandYellowBrush}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- HWID Card -->
                    <Border Grid.Column="4"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE770;" FontSize="13"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                                <TextBlock Text="HWID"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           CharacterSpacing="200"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse x:Name="HwidDot" Width="8" Height="8" Fill="{StaticResource BrandSuccessBrush}"/>
                                <TextBlock x:Name="CardHwid"
                                           Text="—"
                                           Foreground="{StaticResource BrandTextBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Inject Panel -->
                <Border Background="{StaticResource BrandSurfaceBrush}"
                        BorderBrush="{StaticResource BrandBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="24,22"
                        Margin="0,0,0,16">
                    <StackPanel Spacing="20">

                        <!-- Panel Title -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE756;" FontSize="16"
                                      Foreground="{StaticResource BrandYellowBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Inject"
                                       Foreground="{StaticResource BrandTextBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <!-- Status pill -->
                            <Border x:Name="InjectStatusPill"
                                    Background="{StaticResource BrandSurface2Brush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="10,4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse x:Name="StatusDot" Width="7" Height="7"
                                             Fill="{StaticResource BrandMutedBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusLabel"
                                               Text="Not Injected"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Target Process Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="TARGET PROCESS"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           CharacterSpacing="150"/>
                                <ComboBox x:Name="ProcessCombo"
                                          HorizontalAlignment="Stretch"
                                          Height="40"
                                          Background="{StaticResource BrandSurface2Brush}"
                                          BorderBrush="{StaticResource BrandBorderBrush}"
                                          Foreground="{StaticResource BrandTextBrush}"
                                          FontFamily="Segoe UI Variable Text"
                                          FontSize="13"
                                          CornerRadius="6">
                                    <ComboBoxItem Content="RocketLeague.exe" IsSelected="True"/>
                                    <ComboBoxItem Content="RocketLeague_UE4.exe"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- DLL Path -->
                            <StackPanel Grid.Column="2" Spacing="6" Width="200">
                                <TextBlock Text="DLL PATH"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="10"
                                           CharacterSpacing="150"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DllPathBox"
                                             Grid.Column="0"
                                             Style="{StaticResource YxllowTextBoxStyle}"
                                             PlaceholderText="yxllow_sdk.dll"
                                             Height="40"
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="2"
                                            Height="40"
                                            Width="40"
                                            Background="{StaticResource BrandSurface2Brush}"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="0"
                                            Click="BrowseBtn_Click"
                                            ToolTipService.ToolTip="Browse">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="13"
                                                  Foreground="{StaticResource BrandMutedBrush}"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Options Row -->
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <CheckBox x:Name="AutoInjectCheck"
                                      Content="Auto-inject on launch"
                                      Foreground="{StaticResource BrandMutedBrush}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="13"/>
                            <CheckBox x:Name="StealthCheck"
                                      Content="Stealth mode"
                                      Foreground="{StaticResource BrandMutedBrush}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="13"/>
                        </StackPanel>

                        <!-- Inject Button -->
                        <Button x:Name="InjectBtn"
                                Style="{StaticResource YxllowButtonStyle}"
                                Height="46"
                                HorizontalAlignment="Stretch"
                                Click="InjectBtn_Click">
                            <Grid>
                                <StackPanel x:Name="InjectBtnContent"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE756;" FontSize="14" Foreground="#0A0A0A"/>
                                    <TextBlock Text="INJECT"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               CharacterSpacing="100"
                                               Foreground="#0A0A0A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="InjectSpinner"
                                              Width="20" Height="20"
                                              Foreground="#0A0A0A"
                                              Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- Console / Log -->
                <Border Background="{StaticResource BrandSurfaceBrush}"
                        BorderBrush="{StaticResource BrandBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0">
                    <StackPanel>
                        <!-- Console Header -->
                        <Grid Padding="18,12" BorderBrush="{StaticResource BrandBorderBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE756;" FontSize="12"
                                          Foreground="{StaticResource BrandMutedBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Console"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,4"
                                    Click="ClearLog_Click">
                                <TextBlock Text="clear"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="11"/>
                            </Button>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BrandBorderBrush}"/>

                        <!-- Log Entries -->
                        <ScrollViewer x:Name="LogScroll" Height="120" Padding="18,12">
                            <StackPanel x:Name="LogPanel" Spacing="3"/>
                        </ScrollViewer>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
