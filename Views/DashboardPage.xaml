<Page
    x:Class="YxllowLoader.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBgBrush}"
    Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Inject overlay animation: three rings + pulsing center -->
        <Storyboard x:Name="InjectSpinAnim" RepeatBehavior="Forever">
            <!-- Outer ring: slow clockwise, 3 s -->
            <DoubleAnimation Storyboard.TargetName="Ring1Rotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360"
                             Duration="0:0:3"/>
            <!-- Middle ring: medium counter-clockwise, 2 s -->
            <DoubleAnimation Storyboard.TargetName="Ring2Rotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="-360"
                             Duration="0:0:2"/>
            <!-- Inner filled square: pulse scale, 0.9 s auto-reverse -->
            <DoubleAnimation Storyboard.TargetName="Ring3Pulse"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.75" To="1.0"
                             Duration="0:0:0.9"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Ring3Pulse"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.75" To="1.0"
                             Duration="0:0:0.9"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Opening animation: fade in + gentle scale up -->
        <Storyboard x:Name="PageOpenAnim">
            <DoubleAnimation Storyboard.TargetName="PageRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PageRootTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.97" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PageRootTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.97" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="PageRoot" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="PageRootTransform"/>
        </Grid.RenderTransform>

        <!-- ── Gradient background ─────────────────────────────────────── -->

        <!-- Top-left yellow glow -->
        <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#20FFC300" Offset="0"/>
                    <GradientStop Color="#00080808" Offset="0.5"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Bottom-right secondary glow -->
        <Ellipse Width="650" Height="650"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-180,-180">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#14FFC300" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ── Main layout ─────────────────────────────────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Bottom nav bar -->
            </Grid.RowDefinitions>

            <!-- ── Page content ────────────────────────────────────────── -->
            <Grid Grid.Row="0">

                <!-- ═══════════════════════════════════════════════════════
                     INJECT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="InjectView" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="32">

                        <!-- Title -->
                        <StackPanel HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="ROCKET LEAGUE SDK"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="250"/>
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="42">
                                <Run Text="yxllow" Foreground="{StaticResource BrandYellowBrush}"/><Run Text=".tech" Foreground="{StaticResource BrandMutedBrush}" FontSize="28"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Big inject button -->
                        <Button x:Name="InjectBtn"
                                Style="{StaticResource YxllowButtonStyle}"
                                Width="260"
                                Height="56"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="InjectBtn_PointerEntered"
                                PointerExited="InjectBtn_PointerExited"
                                Click="InjectBtn_Click">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <Grid>
                                <StackPanel x:Name="InjectBtnContent"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="10">
                                    <FontIcon Glyph="&#xE756;" FontSize="16"
                                              Foreground="#0A0A0A"/>
                                    <TextBlock Text="INJECT"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="15"
                                               CharacterSpacing="150"
                                               Foreground="#0A0A0A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="InjectSpinner"
                                              Width="22" Height="22"
                                              Foreground="#0A0A0A"
                                              Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <!-- Status indicator -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Ellipse x:Name="StatusDot"
                                     Width="8" Height="8"
                                     Fill="{StaticResource BrandMutedBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="Not Injected"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Info note -->
                        <TextBlock Text="Make sure Rocket League is running before injecting."
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Opacity="0.6"/>

                    </StackPanel>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════
                     ACCOUNT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="AccountView" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="28"
                                MaxWidth="480">

                        <!-- Heading -->
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="ACCOUNT DETAILS"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="250"/>
                            <!-- Avatar circle -->
                            <Border Width="64" Height="64"
                                    CornerRadius="32"
                                    Background="{StaticResource BrandYellowBrush}"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                                <TextBlock x:Name="AvatarInitial"
                                           Text="?"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="Bold"
                                           FontSize="26"
                                           Foreground="#0A0A0A"/>
                            </Border>
                            <TextBlock x:Name="AccountUsername"
                                       Text="..."
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandTextBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="20"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Info cards grid -->
                        <Grid ColumnSpacing="14" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Plan -->
                            <Border Grid.Column="0" Grid.Row="0"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="StatCard_PointerEntered"
                                    PointerExited="StatCard_PointerExited">
                                <Border.RenderTransform>
                                    <CompositeTransform/>
                                </Border.RenderTransform>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="PLAN"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardPlan"
                                               Text="..."
                                               Foreground="{StaticResource BrandYellowBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Expires -->
                            <Border Grid.Column="1" Grid.Row="0"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="StatCard_PointerEntered"
                                    PointerExited="StatCard_PointerExited">
                                <Border.RenderTransform>
                                    <CompositeTransform/>
                                </Border.RenderTransform>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="EXPIRES"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardExpiry"
                                               Text="..."
                                               Foreground="{StaticResource BrandTextBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Days left -->
                            <Border Grid.Column="0" Grid.Row="1"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="StatCard_PointerEntered"
                                    PointerExited="StatCard_PointerExited">
                                <Border.RenderTransform>
                                    <CompositeTransform/>
                                </Border.RenderTransform>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="DAYS LEFT"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardDaysLeft"
                                               Text="..."
                                               Foreground="{StaticResource BrandTextBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- HWID -->
                            <Border Grid.Column="1" Grid.Row="1"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="StatCard_PointerEntered"
                                    PointerExited="StatCard_PointerExited">
                                <Border.RenderTransform>
                                    <CompositeTransform/>
                                </Border.RenderTransform>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="HWID"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse x:Name="HwidDot"
                                                 Width="8" Height="8"
                                                 Fill="{StaticResource BrandSuccessBrush}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CardHwid"
                                                   Text="..."
                                                   Foreground="{StaticResource BrandTextBrush}"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Bold"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>

                    </StackPanel>
                </Grid>

            </Grid>

            <!-- ── Bottom navigation bar ───────────────────────────────── -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="28,0">
                <Grid Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>    <!-- Left: Username -->
                        <ColumnDefinition Width="Auto"/> <!-- Center: Nav tabs -->
                        <ColumnDefinition Width="*"/>    <!-- Right: Logout -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: username -->
                    <TextBlock x:Name="NavUsername"
                               Grid.Column="0"
                               Text="..."
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>

                    <!-- Center: Nav tabs -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">

                        <!-- Inject tab -->
                        <Button x:Name="TabInjectBtn"
                                Click="TabInjectBtn_Click"
                                Background="#1AFFC300"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="TabBtn_PointerEntered"
                                PointerExited="TabBtn_PointerExited">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE756;" FontSize="13"
                                          Foreground="{StaticResource BrandYellowBrush}"/>
                                <TextBlock x:Name="TabInjectText"
                                           Text="INJECT"
                                           Foreground="{StaticResource BrandYellowBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Account tab -->
                        <Button x:Name="TabAccountBtn"
                                Click="TabAccountBtn_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="TabBtn_PointerEntered"
                                PointerExited="TabBtn_PointerExited">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="13"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                                <TextBlock x:Name="TabAccountText"
                                           Text="ACCOUNT"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Right: logout button -->
                    <Button x:Name="LogoutBtn"
                            Grid.Column="2"
                            Background="Transparent"
                            BorderBrush="#44EF4444"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="14,9"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            PointerEntered="LogoutBtn_PointerEntered"
                            PointerExited="LogoutBtn_PointerExited"
                            Click="LogoutBtn_Click">
                        <Button.RenderTransform>
                            <CompositeTransform/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE7E8;"
                                      FontSize="12"
                                      Foreground="#EF4444"/>
                            <TextBlock Text="LOG OUT"
                                       Foreground="#EF4444"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="100"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <!-- ── Inject overlay (covers entire UI during injection) ────────── -->
        <Grid x:Name="InjectOverlay"
              Visibility="Collapsed"
              Background="#CC000000">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="28">

                <!-- Modern three-ring spinner -->
                <Grid Width="120" Height="120" HorizontalAlignment="Center">

                    <!-- Outer ring with rotation indicator stripe -->
                    <Border Width="112" Height="112"
                            BorderBrush="{StaticResource BrandYellowBrush}"
                            BorderThickness="2.5"
                            CornerRadius="14"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="Ring1Rotate"/>
                        </Border.RenderTransform>
                        <!-- Indicator stripe so rotation is visible -->
                        <Border Width="22" Height="3"
                                Background="{StaticResource BrandYellowBrush}"
                                CornerRadius="1.5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,3,0,0"/>
                    </Border>

                    <!-- Middle ring -->
                    <Border Width="74" Height="74"
                            BorderBrush="{StaticResource BrandYellowBrush}"
                            BorderThickness="2"
                            CornerRadius="9"
                            Opacity="0.7"
                            RenderTransformOrigin="0.5,0.5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="Ring2Rotate"/>
                        </Border.RenderTransform>
                        <Border Width="14" Height="2.5"
                                Background="{StaticResource BrandYellowBrush}"
                                CornerRadius="1.25"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,2,0,0"/>
                    </Border>

                    <!-- Inner pulsing filled square -->
                    <Border Width="36" Height="36"
                            Background="{StaticResource BrandYellowBrush}"
                            CornerRadius="6"
                            Opacity="0.95"
                            RenderTransformOrigin="0.5,0.5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <CompositeTransform x:Name="Ring3Pulse"/>
                        </Border.RenderTransform>
                    </Border>

                    <!-- Center bright dot -->
                    <Ellipse Width="8" Height="8"
                             Fill="White"
                             Opacity="0.9"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Grid>

                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="OverlayStatus"
                               Text="Injecting..."
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="16"
                               CharacterSpacing="100"/>
                    <TextBlock Text="Please wait"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- Version watermark -->
        <TextBlock Text="v1.0.0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,16,68"
                   Foreground="{StaticResource BrandMutedBrush}"
                   FontFamily="Segoe UI Variable Text"
                   FontSize="11"
                   Opacity="0.4"/>
    </Grid>
</Page>
