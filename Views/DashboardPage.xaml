<Page
    x:Class="YxllowLoader.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBgBrush}">

    <Grid>

        <!-- ── Gradient background ─────────────────────────────────────── -->

        <!-- Top-left yellow glow -->
        <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#20FFC300" Offset="0"/>
                    <GradientStop Color="#00080808" Offset="0.5"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Bottom-right secondary glow -->
        <Ellipse Width="650" Height="650"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-180,-180">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#14FFC300" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ── Main layout ─────────────────────────────────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Top navigation bar ──────────────────────────────────── -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,0">
                <Grid Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Spacing="2">
                        <TextBlock FontFamily="Segoe UI Variable Display"
                                   FontWeight="Bold" FontSize="20">
                            <Run Text="yxllow" Foreground="{StaticResource BrandYellowBrush}"/>
                            <Run Text=".tech" Foreground="{StaticResource BrandMutedBrush}" FontSize="15"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Nav tabs (center) -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">

                        <!-- Inject tab -->
                        <Button x:Name="TabInjectBtn"
                                Click="TabInjectBtn_Click"
                                Background="#1AFFC300"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE756;" FontSize="13"
                                          Foreground="{StaticResource BrandYellowBrush}"/>
                                <TextBlock x:Name="TabInjectText"
                                           Text="INJECT"
                                           Foreground="{StaticResource BrandYellowBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Account tab -->
                        <Button x:Name="TabAccountBtn"
                                Click="TabAccountBtn_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="13"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                                <TextBlock x:Name="TabAccountText"
                                           Text="ACCOUNT"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Right: username + logout -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="12">
                        <TextBlock x:Name="NavUsername"
                                   Text="..."
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="6"
                                VerticalAlignment="Center"
                                Click="LogoutBtn_Click"
                                ToolTipService.ToolTip="Logout">
                            <FontIcon Glyph="&#xE8BB;" FontSize="14"
                                      Foreground="{StaticResource BrandMutedBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Page content ────────────────────────────────────────── -->
            <Grid Grid.Row="1">

                <!-- ═══════════════════════════════════════════════════════
                     INJECT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="InjectView" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="32">

                        <!-- Title -->
                        <StackPanel HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="ROCKET LEAGUE SDK"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="250"/>
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="42">
                                <Run Text="yxllow" Foreground="{StaticResource BrandYellowBrush}"/>
                                <Run Text=".tech" Foreground="{StaticResource BrandMutedBrush}" FontSize="28"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Big inject button -->
                        <Button x:Name="InjectBtn"
                                Style="{StaticResource YxllowButtonStyle}"
                                Width="260"
                                Height="56"
                                HorizontalAlignment="Center"
                                Click="InjectBtn_Click">
                            <Grid>
                                <StackPanel x:Name="InjectBtnContent"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="10">
                                    <FontIcon Glyph="&#xE756;" FontSize="16"
                                              Foreground="#0A0A0A"/>
                                    <TextBlock Text="INJECT"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="15"
                                               CharacterSpacing="150"
                                               Foreground="#0A0A0A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="InjectSpinner"
                                              Width="22" Height="22"
                                              Foreground="#0A0A0A"
                                              Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <!-- Status indicator -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Ellipse x:Name="StatusDot"
                                     Width="8" Height="8"
                                     Fill="{StaticResource BrandMutedBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="Not Injected"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Info note -->
                        <TextBlock Text="Make sure Rocket League is running before injecting."
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Opacity="0.6"/>

                    </StackPanel>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════
                     ACCOUNT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="AccountView" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="28"
                                MaxWidth="480">

                        <!-- Heading -->
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="ACCOUNT DETAILS"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="250"/>
                            <!-- Avatar circle -->
                            <Border Width="64" Height="64"
                                    CornerRadius="32"
                                    Background="{StaticResource BrandYellowBrush}"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                                <TextBlock x:Name="AvatarInitial"
                                           Text="?"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="Bold"
                                           FontSize="26"
                                           Foreground="#0A0A0A"/>
                            </Border>
                            <TextBlock x:Name="AccountUsername"
                                       Text="..."
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandTextBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="20"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- Info cards grid -->
                        <Grid ColumnSpacing="14" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Plan -->
                            <Border Grid.Column="0" Grid.Row="0"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="PLAN"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardPlan"
                                               Text="..."
                                               Foreground="{StaticResource BrandYellowBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Expires -->
                            <Border Grid.Column="1" Grid.Row="0"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="EXPIRES"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardExpiry"
                                               Text="..."
                                               Foreground="{StaticResource BrandTextBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Days left -->
                            <Border Grid.Column="0" Grid.Row="1"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="DAYS LEFT"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <TextBlock x:Name="CardDaysLeft"
                                               Text="..."
                                               Foreground="{StaticResource BrandTextBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="18"/>
                                </StackPanel>
                            </Border>

                            <!-- HWID -->
                            <Border Grid.Column="1" Grid.Row="1"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="20,16">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="HWID"
                                               Foreground="{StaticResource BrandMutedBrush}"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="SemiBold"
                                               FontSize="10"
                                               CharacterSpacing="200"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse x:Name="HwidDot"
                                                 Width="8" Height="8"
                                                 Fill="{StaticResource BrandSuccessBrush}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CardHwid"
                                                   Text="..."
                                                   Foreground="{StaticResource BrandTextBrush}"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Bold"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </Grid>

                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>

        <!-- Version watermark -->
        <TextBlock Text="v1.0.0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,16,12"
                   Foreground="{StaticResource BrandMutedBrush}"
                   FontFamily="Segoe UI Variable Text"
                   FontSize="11"
                   Opacity="0.4"/>
    </Grid>
</Page>
