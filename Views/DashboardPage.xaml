<Page
    x:Class="YxllowLoader.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBgBrush}"
    Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Cursor blink animation for the upload prompt -->
        <Storyboard x:Name="CursorBlinkAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TerminalCursor"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0"
                             Duration="0:0:0.55"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Car pulse animation while uploading -->
        <Storyboard x:Name="CarPulseAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="CarTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.1"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CarTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.1"
                             Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Upload arrows pulse animation -->
        <Storyboard x:Name="ArrowsAnim" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="UploadArrows"
                             Storyboard.TargetProperty="Opacity"
                             From="0.15" To="0.9"
                             Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Opening animation: fade in + gentle scale up -->
        <Storyboard x:Name="PageOpenAnim">
            <DoubleAnimation Storyboard.TargetName="PageRoot"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PageRootTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.97" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PageRootTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.97" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="PageRoot" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="PageRootTransform"/>
        </Grid.RenderTransform>

        <!-- ── Gradient background ─────────────────────────────────────── -->

        <!-- Top-left yellow glow -->
        <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#20FFC300" Offset="0"/>
                    <GradientStop Color="#00080808" Offset="0.5"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Bottom-right secondary glow -->
        <Ellipse Width="650" Height="650"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-180,-180">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#14FFC300" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ── Main layout ─────────────────────────────────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Bottom nav bar -->
            </Grid.RowDefinitions>

            <!-- ── Page content ────────────────────────────────────────── -->
            <Grid Grid.Row="0">

                <!-- ═══════════════════════════════════════════════════════
                     INJECT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="InjectView" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="32">

                        <!-- Title -->
                        <StackPanel HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="ROCKET LEAGUE SDK"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="250"/>
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="42">
                                <Run Text="yxllow" Foreground="{StaticResource BrandYellowBrush}"/><Run Text=".tech" Foreground="{StaticResource BrandMutedBrush}" FontSize="28"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Big inject button -->
                        <Button x:Name="InjectBtn"
                                Style="{StaticResource YxllowButtonStyle}"
                                Width="260"
                                Height="56"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="InjectBtn_PointerEntered"
                                PointerExited="InjectBtn_PointerExited"
                                Click="InjectBtn_Click">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <Grid>
                                <StackPanel x:Name="InjectBtnContent"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="10">
                                    <FontIcon Glyph="&#xE756;" FontSize="16"
                                              Foreground="#0A0A0A"/>
                                    <TextBlock Text="INJECT"
                                               FontFamily="Segoe UI Variable Display"
                                               FontWeight="Bold"
                                               FontSize="15"
                                               CharacterSpacing="150"
                                               Foreground="#0A0A0A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ProgressRing x:Name="InjectSpinner"
                                              Width="22" Height="22"
                                              Foreground="#0A0A0A"
                                              Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <!-- Status indicator -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Ellipse x:Name="StatusDot"
                                     Width="8" Height="8"
                                     Fill="{StaticResource BrandMutedBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="Not Injected"
                                       Foreground="{StaticResource BrandMutedBrush}"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Info note -->
                        <TextBlock Text="Make sure Rocket League is running before injecting."
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="12"
                                   Opacity="0.6"/>

                    </StackPanel>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════
                     ACCOUNT VIEW
                ═══════════════════════════════════════════════════════ -->
                <Grid x:Name="AccountView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">

                        <StackPanel HorizontalAlignment="Center"
                                    MaxWidth="500"
                                    Spacing="14">

                            <!-- ── Profile header card ───────────────────────── -->
                            <Border CornerRadius="12"
                                    Padding="0"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <!-- Gradient banner strip -->
                                    <Border CornerRadius="12,12,0,0" Height="72"
                                            VerticalAlignment="Top">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#35FFC300" Offset="0"/>
                                                <GradientStop Color="#18FFC300" Offset="0.6"/>
                                                <GradientStop Color="#06080808" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <!-- Decorative Y mark top-right -->
                                        <TextBlock Text="Y"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,24,0"
                                                   Foreground="#18FFC300"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Black"
                                                   FontSize="56"/>
                                    </Border>

                                    <!-- Profile info below banner -->
                                    <StackPanel Margin="24,44,24,20" Spacing="0">

                                        <!-- Avatar (overlaps the banner) -->
                                        <Border Width="72" Height="72"
                                                CornerRadius="36"
                                                Background="{StaticResource BrandYellowBrush}"
                                                BorderBrush="{StaticResource BrandSurfaceBrush}"
                                                BorderThickness="4"
                                                HorizontalAlignment="Left">
                                            <TextBlock x:Name="AvatarInitial"
                                                       Text="?"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="Bold"
                                                       FontSize="30"
                                                       Foreground="#0A0A0A"/>
                                        </Border>

                                        <!-- Username + plan badge -->
                                        <StackPanel Spacing="6" Margin="0,10,0,0">
                                            <TextBlock x:Name="AccountUsername"
                                                       Text="..."
                                                       Foreground="{StaticResource BrandTextBrush}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="Bold"
                                                       FontSize="22"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <!-- Plan badge -->
                                                <Border Background="#22FFC300"
                                                        BorderBrush="#44FFC300"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="10,3">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <FontIcon Glyph="&#xE7BF;"
                                                                  FontSize="10"
                                                                  Foreground="{StaticResource BrandYellowBrush}"/>
                                                        <TextBlock x:Name="CardPlan"
                                                                   Text="..."
                                                                   Foreground="{StaticResource BrandYellowBrush}"
                                                                   FontFamily="Segoe UI Variable Display"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="11"
                                                                   CharacterSpacing="80"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── Subscription cards (2-col) ──────────────── -->
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Expires -->
                                <Border Grid.Column="0"
                                        Background="{StaticResource BrandSurfaceBrush}"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="18,16"
                                        RenderTransformOrigin="0.5,0.5"
                                        PointerEntered="StatCard_PointerEntered"
                                        PointerExited="StatCard_PointerExited">
                                    <Border.RenderTransform>
                                        <CompositeTransform/>
                                    </Border.RenderTransform>
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon Glyph="&#xE787;"
                                                      FontSize="13"
                                                      Foreground="{StaticResource BrandMutedBrush}"/>
                                            <TextBlock Text="EXPIRES"
                                                       Foreground="{StaticResource BrandMutedBrush}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       FontSize="10"
                                                       CharacterSpacing="180"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="CardExpiry"
                                                   Text="..."
                                                   Foreground="{StaticResource BrandTextBrush}"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Bold"
                                                   FontSize="16"/>
                                    </StackPanel>
                                </Border>

                                <!-- Days left -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource BrandSurfaceBrush}"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="18,16"
                                        RenderTransformOrigin="0.5,0.5"
                                        PointerEntered="StatCard_PointerEntered"
                                        PointerExited="StatCard_PointerExited">
                                    <Border.RenderTransform>
                                        <CompositeTransform/>
                                    </Border.RenderTransform>
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon Glyph="&#xE823;"
                                                      FontSize="13"
                                                      Foreground="{StaticResource BrandMutedBrush}"/>
                                            <TextBlock Text="DAYS LEFT"
                                                       Foreground="{StaticResource BrandMutedBrush}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       FontSize="10"
                                                       CharacterSpacing="180"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="CardDaysLeft"
                                                   Text="..."
                                                   Foreground="{StaticResource BrandTextBrush}"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Bold"
                                                   FontSize="16"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ── HWID card (full width) ────────────────── -->
                            <Border Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="18,16"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="StatCard_PointerEntered"
                                    PointerExited="StatCard_PointerExited">
                                <Border.RenderTransform>
                                    <CompositeTransform/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon Glyph="&#xE72E;"
                                                      FontSize="13"
                                                      Foreground="{StaticResource BrandMutedBrush}"/>
                                            <TextBlock Text="HARDWARE ID"
                                                       Foreground="{StaticResource BrandMutedBrush}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       FontSize="10"
                                                       CharacterSpacing="180"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="CardHwid"
                                                   Text="..."
                                                   Foreground="{StaticResource BrandTextBrush}"
                                                   FontFamily="Segoe UI Variable Display"
                                                   FontWeight="Bold"
                                                   FontSize="16"/>
                                    </StackPanel>
                                    <!-- Status indicator pill -->
                                    <Border Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Padding="10,5"
                                            CornerRadius="20">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="HwidPillBg" Color="#1A22C55E"/>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse x:Name="HwidDot"
                                                     Width="7" Height="7"
                                                     Fill="{StaticResource BrandSuccessBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock x:Name="HwidStatusText"
                                                       Text="Verified"
                                                       Foreground="{StaticResource BrandSuccessBrush}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- ── Bottom navigation bar ───────────────────────────────── -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="28,0">
                <Grid Height="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>    <!-- Left: Username -->
                        <ColumnDefinition Width="Auto"/> <!-- Center: Nav tabs -->
                        <ColumnDefinition Width="*"/>    <!-- Right: Logout -->
                    </Grid.ColumnDefinitions>

                    <!-- Left: username -->
                    <TextBlock x:Name="NavUsername"
                               Grid.Column="0"
                               Text="..."
                               Foreground="{StaticResource BrandMutedBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>

                    <!-- Center: Nav tabs -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">

                        <!-- Inject tab -->
                        <Button x:Name="TabInjectBtn"
                                Click="TabInjectBtn_Click"
                                Background="#1AFFC300"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="TabBtn_PointerEntered"
                                PointerExited="TabBtn_PointerExited">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE756;" FontSize="13"
                                          Foreground="{StaticResource BrandYellowBrush}"/>
                                <TextBlock x:Name="TabInjectText"
                                           Text="INJECT"
                                           Foreground="{StaticResource BrandYellowBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Account tab -->
                        <Button x:Name="TabAccountBtn"
                                Click="TabAccountBtn_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="7"
                                Padding="20,8"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="TabBtn_PointerEntered"
                                PointerExited="TabBtn_PointerExited">
                            <Button.RenderTransform>
                                <CompositeTransform/>
                            </Button.RenderTransform>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="13"
                                          Foreground="{StaticResource BrandMutedBrush}"/>
                                <TextBlock x:Name="TabAccountText"
                                           Text="ACCOUNT"
                                           Foreground="{StaticResource BrandMutedBrush}"
                                           FontFamily="Segoe UI Variable Display"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           CharacterSpacing="100"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Right: logout button -->
                    <Button x:Name="LogoutBtn"
                            Grid.Column="2"
                            Background="Transparent"
                            BorderBrush="#44EF4444"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="14,9"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            PointerEntered="LogoutBtn_PointerEntered"
                            PointerExited="LogoutBtn_PointerExited"
                            Click="LogoutBtn_Click">
                        <Button.RenderTransform>
                            <CompositeTransform/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE7E8;"
                                      FontSize="12"
                                      Foreground="#EF4444"/>
                            <TextBlock Text="LOG OUT"
                                       Foreground="#EF4444"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       CharacterSpacing="100"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <!-- ── Inject overlay (covers entire UI during injection) ────────── -->
        <Grid x:Name="InjectOverlay"
              Visibility="Collapsed"
              Background="#D9000000">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20"
                        MinWidth="480">

                <!-- Upload visualization card -->
                <Border Background="#0D0D0D"
                        BorderBrush="#33FFC300"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20">
                    <StackPanel Spacing="16">

                        <!-- Header -->
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock Text="⚡ UPLOADING TO ROCKET LEAGUE"
                                       HorizontalAlignment="Center"
                                       Foreground="#FFC300"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       CharacterSpacing="80"/>
                            <TextBlock Text="Beaming SDK directly into your car"
                                       HorizontalAlignment="Center"
                                       Foreground="#555555"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- Car upload visualizer -->
                        <Border Background="#080808"
                                CornerRadius="8"
                                Height="130"
                                ClipToBounds="True">
                            <Grid>
                                <!-- Code stream panel (left side) -->
                                <StackPanel HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Padding="14,0,0,0"
                                            Spacing="4"
                                            Width="155">
                                    <Border Background="#0D1A0D" CornerRadius="4" Padding="8,6">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="FlyCode1"
                                                       Text=""
                                                       Foreground="#44FF44"
                                                       FontFamily="Consolas"
                                                       FontSize="10"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock x:Name="FlyCode2"
                                                       Text=""
                                                       Foreground="#44FF44"
                                                       FontFamily="Consolas"
                                                       FontSize="10"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock x:Name="FlyCode3"
                                                       Text=""
                                                       Foreground="#88FF88"
                                                       FontFamily="Consolas"
                                                       FontSize="10"
                                                       TextWrapping="NoWrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Upload arrows (center) -->
                                <TextBlock x:Name="UploadArrows"
                                           Text="══►══►══►"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#FFC300"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Opacity="0.5"/>

                                <!-- Rocket League car (right side) -->
                                <StackPanel HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Padding="0,0,14,0"
                                            Spacing="0">
                                    <TextBlock x:Name="BoostFlame"
                                               Text=""
                                               HorizontalAlignment="Left"
                                               Margin="6,0,0,0"
                                               FontSize="18"/>
                                    <TextBlock Text="🏎️"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <CompositeTransform x:Name="CarTransform"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Upload log (scrolling code lines) -->
                        <Border Background="#080808" CornerRadius="6" Padding="14,10">
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="CodeLine1" Text="" Foreground="#44FF44"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                                <TextBlock x:Name="CodeLine2" Text="" Foreground="#44FF44"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                                <TextBlock x:Name="CodeLine3" Text="" Foreground="#44FF44"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                                <TextBlock x:Name="CodeLine4" Text="" Foreground="#FFC300"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>
                                <TextBlock x:Name="CodeLine5" Text="" Foreground="#FFC300"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap"/>

                                <!-- Active prompt line with blinking cursor -->
                                <StackPanel Orientation="Horizontal" Spacing="0" Margin="0,4,0,0">
                                    <TextBlock x:Name="CodePrompt"
                                               Text="&gt; "
                                               Foreground="#FFC300"
                                               FontFamily="Consolas"
                                               FontSize="11"/>
                                    <TextBlock x:Name="CodeCurrent"
                                               Text=""
                                               Foreground="#FFC300"
                                               FontFamily="Consolas"
                                               FontSize="11"/>
                                    <TextBlock x:Name="TerminalCursor"
                                               Text="█"
                                               Foreground="#FFC300"
                                               FontFamily="Consolas"
                                               FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Boost meter -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="BOOST"
                                       Foreground="#FFC300"
                                       FontFamily="Segoe UI Variable Display"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       CharacterSpacing="80"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ProgressBar x:Name="InjectProgressBar"
                                         Grid.Column="1"
                                         Minimum="0" Maximum="100" Value="0"
                                         Foreground="{StaticResource BrandYellowBrush}"
                                         Background="#1A1A1A"
                                         Height="10"
                                         VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Status text below card -->
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="OverlayStatus"
                               Text="Uploading..."
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontFamily="Segoe UI Variable Display"
                               FontWeight="SemiBold"
                               FontSize="15"
